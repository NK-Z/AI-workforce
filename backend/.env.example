# Required: Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Required: Generate a random secret (e.g., openssl rand -hex 32)
JWT_SECRET=your-secret-key-change-in-production

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./ai_workforce.db

# Claude model for agent chat
CLAUDE_MODEL=claude-sonnet-4-5

# Frontend URL (for CORS and calendar redirect)
FRONTEND_URL=http://localhost:5500

# Optional: Google Calendar integration
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/callback

# Rate limit (messages per minute per user)
CHAT_RATE_LIMIT=20
